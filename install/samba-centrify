LD_LIBRARY_PATH=/usr/share/centrifydc/lib64: /usr/share/centrifydc/kerberos/lib64: $LD_LIBRARY_PATH
export LD_LIBRARY_PATH
perl /usr/share/centrifydc/bin/adbindproxy.pl
